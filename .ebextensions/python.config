option_settings:
  # Health check — hit /health (no DB, no auth) instead of / (redirects)
  aws:elasticbeanstalk:environment:process:default:
    HealthCheckPath: /health
    Port: 8000
    Protocol: HTTP

  # Application environment
  aws:elasticbeanstalk:application:environment:
    FLASK_ENV: production
    LOG_DIR: /tmp/logs
    UPLOAD_FOLDER: /tmp/uploads
    # EB_ENV_NAME: set via `eb setenv EB_ENV_NAME=<env-name>` to pin the
    # Horizon App Infrastructure boto3 query to a specific environment.
    # If unset, Horizon auto-detects by listing all active environments.
    # S3_FULFILLMENT_BUCKET: set via `eb setenv S3_FULFILLMENT_BUCKET=<bucket-name>`
    # S3_BUCKET_REGION: defaults to us-east-1; override if bucket is in another region.

  # Platform tuning
  aws:elasticbeanstalk:container:python:
    NumProcesses: 2
    NumThreads: 15

  # Allow up to 20 minutes for pip install (boto3+botocore are large)
  aws:elasticbeanstalk:command:
    Timeout: 1200
    IgnoreHealthCheck: false
