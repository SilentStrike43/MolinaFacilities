version: 1.0
runtime: python311

build:
  commands:
    build:
      - python3 --version

run:
  runtime-version: 3.11
  pre-run:
    - pip3 --version
    - pip3 install -r requirements.txt
  command: python3 -m gunicorn app.app:application --bind 0.0.0.0:8000
  network:
    port: 8000
  env:
    - name: PYTHONUNBUFFERED
      value: "1"
