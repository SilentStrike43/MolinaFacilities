# app/modules/fulfillment/views.py - FIXED PERMISSION CHECKS
import os
import json
import datetime
import mimetypes
from flask import Blueprint, render_template, request, redirect, url_for, flash, g, send_file, abort
from werkzeug.utils import secure_filename

from app.modules.auth.security import login_required, current_user, record_audit
from app.modules.users.permissions import PermissionManager
from app.core.database import get_db_connection

# module-local DB
from app.modules.fulfillment.storage import ensure_schema

fulfillment_bp = Blueprint("fulfillment", __name__, url_prefix="/fulfillment", template_folder="templates")
bp = fulfillment_bp

STATUS_CHOICES = [
    "Received", "Hold", "In-Progress", "Suspended",
    "Cancelled", "Completed", "Archive"
]

# Upload directory
DATA_DIR = os.path.join(os.path.dirname(os.path.dirname(os.path.dirname(__file__))), "data")
UPLOAD_DIR = os.path.join(DATA_DIR, "fulfillment_uploads")
os.makedirs(UPLOAD_DIR, exist_ok=True)

# ---------- Schema setup ----------
ensure_schema()

# ---------- Database helpers ----------
def create_request(data: dict, user_location: str = 'NY') -> int:
    """Create a new service request with location."""
    with get_db_connection("fulfillment") as conn:
        cursor = conn.cursor()
        cursor.execute("""
            INSERT INTO service_requests(
                requester_id, requester_name, title, description, 
                request_type, status, location
            ) VALUES (?,?,?,?,?,?,?)
        """, (
            data.get("requester_id"),
            data.get("requester_name"),
            data.get("title", data.get("description", "")[:500]),
            data.get("description"),
            data.get("request_type", "general"),
            data.get("status", "pending"),
            user_location
        ))
        conn.commit()
        
        cursor.execute("SELECT @@IDENTITY")
        rid = int(cursor.fetchone()[0])
        cursor.close()
        return rid

def update_status(request_id: int, status: str, archive: bool = False, staff_id: int = None, staff_name: str = None):
    """Update request status in BOTH tables."""
    with get_db_connection("fulfillment") as conn:
        cursor = conn.cursor()
        
        # Update fulfillment_requests
        if archive:
            cursor.execute("""
                UPDATE fulfillment_requests 
                SET status=?, is_archived=1, assigned_staff_id=?, assigned_staff_name=?,
                    completed_at=GETUTCDATE()
                WHERE id=?
            """, (status, staff_id, staff_name, request_id))
            
            # Also update service_requests
            cursor.execute("""
                UPDATE service_requests
                SET status=?, is_archived=1, completed_at=GETUTCDATE()
                WHERE id=?
            """, (status, request_id))
        else:
            cursor.execute("""
                UPDATE fulfillment_requests 
                SET status=?, assigned_staff_id=?, assigned_staff_name=?
                WHERE id=?
            """, (status, staff_id, staff_name, request_id))
            
            # Also update service_requests
            cursor.execute("""
                UPDATE service_requests
                SET status=?, assigned_to=?
                WHERE id=?
            """, (status, staff_id, request_id))
        
        conn.commit()
        cursor.close()

def list_queue(location=None):
    """List non-archived requests with proper JOIN."""
    with get_db_connection("fulfillment") as conn:
        cursor = conn.cursor()
        
        if location:
            cursor.execute("""
                SELECT 
                    sr.id,
                    sr.created_at,
                    sr.requester_name,
                    sr.description,
                    sr.location,
                    fr.status,
                    fr.assigned_staff_name,
                    fr.is_archived
                FROM service_requests sr
                LEFT JOIN fulfillment_requests fr ON sr.id = fr.id
                WHERE fr.is_archived=FALSE AND sr.location=?
                ORDER BY sr.created_at DESC
            """, (location,))
        else:
            cursor.execute("""
                SELECT 
                    sr.id,
                    sr.created_at,
                    sr.requester_name,
                    sr.description,
                    sr.location,
                    fr.status,
                    fr.assigned_staff_name,
                    fr.is_archived
                FROM service_requests sr
                LEFT JOIN fulfillment_requests fr ON sr.id = fr.id
                WHERE fr.is_archived=FALSE
                ORDER BY sr.created_at DESC
            """)
        
        rows = cursor.fetchall()
        
        # Convert to dicts for easier template access
        result = []
        for row in rows:
            result.append({
                'id': row[0],
                'created_at': row[1],
                'requester_name': row[2],
                'description': row[3],
                'location': row[4],
                'status': row[5] or 'Received',
                'assigned_staff_name': row[6],
                'is_archived': row[7]
            })
        
        cursor.close()
        return result

def list_archive(location=None):
    """List archived requests with proper JOIN."""
    with get_db_connection("fulfillment") as conn:
        cursor = conn.cursor()
        
        if location:
            cursor.execute("""
                SELECT 
                    sr.id,
                    sr.created_at,
                    sr.requester_name,
                    sr.description,
                    sr.location,
                    fr.status,
                    fr.assigned_staff_name,
                    fr.completed_at,
                    fr.is_archived
                FROM service_requests sr
                LEFT JOIN fulfillment_requests fr ON sr.id = fr.id
                WHERE fr.is_archived=TRUE AND sr.location=?
                ORDER BY fr.completed_at DESC, sr.created_at DESC
            """, (location,))
        else:
            cursor.execute("""
                SELECT 
                    sr.id,
                    sr.created_at,
                    sr.requester_name,
                    sr.description,
                    sr.location,
                    fr.status,
                    fr.assigned_staff_name,
                    fr.completed_at,
                    fr.is_archived
                FROM service_requests sr
                LEFT JOIN fulfillment_requests fr ON sr.id = fr.id
                WHERE fr.is_archived=TRUE
                ORDER BY fr.completed_at DESC, sr.created_at DESC
            """)
        
        rows = cursor.fetchall()
        
        # Convert to dicts
        result = []
        for row in rows:
            result.append({
                'id': row[0],
                'created_at': row[1],
                'requester_name': row[2],
                'description': row[3],
                'location': row[4],
                'status': row[5] or 'Completed',
                'assigned_staff_name': row[6],
                'completed_at': row[7],
                'is_archived': row[8]
            })
        
        cursor.close()
        return result

def get_request(request_id: int):
    """Get a single request."""
    with get_db_connection("fulfillment") as conn:
        cursor = conn.cursor()
        cursor.execute("SELECT * FROM fulfillment_requests WHERE id=?", (request_id,))
        row = cursor.fetchone()
        cursor.close()
        return row

def list_files(request_id: int):
    """List files for a request."""
    with get_db_connection("fulfillment") as conn:
        cursor = conn.cursor()
        cursor.execute("""
            SELECT * FROM fulfillment_files 
            WHERE request_id=? 
            ORDER BY ts_utc
        """, (request_id,))
        rows = cursor.fetchall()
        cursor.close()
        return rows

# ---------- FIXED Permission helpers ----------
def _user_can_staff(u) -> bool:
    """Check if user has M3B (Service) or M3C (Manager) permissions."""
    if not u:
        return False
    
    # Check if elevated (admin)
    permission_level = u.get('permission_level', '')
    if permission_level in ['L1', 'L2', 'L3', 'S1']:
        return True
    
    # Check module permissions using PermissionManager
    effective_perms = PermissionManager.get_effective_permissions(u)
    return effective_perms.get('can_fulfillment_service') or effective_perms.get('can_fulfillment_manager')

def _user_can_customer(u) -> bool:
    """Check if user has M3A (Customer), M3B (Service), or M3C (Manager) permissions."""
    if not u:
        return False
    
    # Check if elevated (admin)
    permission_level = u.get('permission_level', '')
    if permission_level in ['L1', 'L2', 'L3', 'S1']:
        return True
    
    # Check module permissions using PermissionManager
    effective_perms = PermissionManager.get_effective_permissions(u)
    return (effective_perms.get('can_fulfillment_customer') or 
            effective_perms.get('can_fulfillment_service') or 
            effective_perms.get('can_fulfillment_manager'))

def _require_staff():
    """Require M3B or M3C permissions."""
    u = current_user()
    if not _user_can_staff(u):
        flash("Fulfillment staff access required. You need M3B (Service) or M3C (Manager) permissions.", "danger")
        return None
    return u

def _require_customer():
    """Require M3A, M3B, or M3C permissions."""
    u = current_user()
    if not _user_can_customer(u):
        flash("Fulfillment access required. You need M3A (Customer), M3B (Service), or M3C (Manager) permissions.", "danger")
        return None
    return u

# ---------- Request Fulfillment (Customer) ----------
@fulfillment_bp.route("/request", methods=["GET", "POST"])
@login_required
def request_form():
    """Submit new fulfillment request."""
    cu = current_user()
    
    # Check permissions
    effective_perms = PermissionManager.get_effective_permissions(cu)
    if not (effective_perms.get("can_fulfillment_customer") or 
            effective_perms.get("can_fulfillment_service") or 
            effective_perms.get("can_fulfillment_manager")):
        flash("You don't have access to Fulfillment.", "danger")
        return redirect(url_for("home.index"))
    
    if request.method == "POST":
    # AUTO-POPULATE requester from current user
        requester_name = f"{cu.get('first_name', '')} {cu.get('last_name', '')}".strip()
        if not requester_name:
                requester_name = cu.get('username', 'Unknown')
    
        description = request.form.get("description", "").strip()
        page_count = int(request.form.get("page_count", 0) or 0)
        
        if not description:
            flash("Description is required.", "danger")
            return redirect(url_for("fulfillment.request_form"))
        
        # Get user location
        user_location = cu.get("location", "NY")
        if user_location not in ["NY", "CT"]:
            user_location = "NY"
        
        try:
            with get_db_connection("fulfillment") as conn:
                cursor = conn.cursor()
                
                # STEP 1: Insert into service_requests first (matches actual schema)
                import datetime
                request_number = f"FR-{datetime.datetime.now().strftime('%Y%m%d')}-{cu['id']}-{datetime.datetime.now().strftime('%H%M%S')}"

                cursor.execute("""
                    INSERT INTO service_requests (
                        request_number, title, description, request_type, 
                        requester_id, requester_name, location,
                        status, is_archived, created_at
                    )
                    OUTPUT INSERTED.id
                    VALUES (?, ?, ?, ?, ?, ?, ?, 'pending', 0, GETDATE())
                """, (
                    request_number,      # unique request_number (FR-YYYYMMDD-USERID-HHMMSS)
                    description[:100],   # title (first 100 chars)
                    description,         # full description
                    'fulfillment',       # request_type
                    cu['id'],           # requester_id (NOT NULL)
                    requester_name,     # requester_name
                    user_location       # location
                ))
                
                request_id = cursor.fetchone()[0]
                
                # STEP 2: Insert into fulfillment_requests (without IDENTITY_INSERT)
                cursor.execute("""
                    SET IDENTITY_INSERT fulfillment_requests ON;
                    
                    INSERT INTO fulfillment_requests (
                        id, requester_id, requester_name, description, 
                        total_pages, date_submitted, status, is_archived
                    )
                    VALUES (?, ?, ?, ?, ?, GETDATE(), 'Received', 0);
                    
                    SET IDENTITY_INSERT fulfillment_requests OFF;
                """, (
                    request_id,      # use same ID from service_requests
                    cu['id'],        # requester_id
                    requester_name,  # requester_name
                    description,     # description
                    page_count       # total_pages
                ))
                
                # STEP 3: Commit the request creation BEFORE adding files
                conn.commit()
                
                # STEP 4: Now handle file uploads with the committed request_id
                files = request.files.getlist("attachments")
                for f in files:
                    if f and f.filename:
                        from werkzeug.utils import secure_filename
                        orig_name = secure_filename(f.filename)
                        ext = os.path.splitext(orig_name)[1].lower()
                        
                        # Generate unique filename
                        import uuid
                        stored_name = f"{uuid.uuid4().hex}{ext}"
                        
                        # Upload folder
                        UPLOAD_FOLDER = os.path.join(os.path.dirname(__file__), "uploads")
                        os.makedirs(UPLOAD_FOLDER, exist_ok=True)
                        file_path = os.path.join(UPLOAD_FOLDER, stored_name)
                        
                        try:
                            f.save(file_path)
                            size = os.path.getsize(file_path)
                            
                            # Insert file record
                            cursor.execute("""
                                INSERT INTO fulfillment_files(
                                    request_id, orig_name, stored_name, ext, bytes, ok
                                )
                                VALUES (?, ?, ?, ?, ?, ?)
                            """, (request_id, orig_name, stored_name, ext, size, 1))
                            
                        except Exception as e:
                            print(f"Error saving file {orig_name}: {e}")
                            # File save failed, mark as error
                            cursor.execute("""
                                INSERT INTO fulfillment_files(
                                    request_id, orig_name, stored_name, ext, bytes, ok
                                )
                                VALUES (?, ?, ?, ?, ?, ?)
                            """, (request_id, orig_name, f"error_{orig_name}", ext, 0, 0))
                
                # Final commit for files
                conn.commit()
                cursor.close()
            
            # Record audit
            record_audit(cu, "create_fulfillment_request", "fulfillment", 
                        f"Created request #{request_id}: {description[:50]}")
            
            flash(f"Request #{request_id} submitted successfully!", "success")
            return redirect(url_for("fulfillment.archive"))
            
        except Exception as e:
            print(f"Error creating fulfillment request: {e}")
            import traceback
            traceback.print_exc()
            flash(f"Error creating request: {str(e)}", "danger")
            return redirect(url_for("fulfillment.request_form"))

    # GET request
    return render_template(
        "fulfillment/request.html",
        active="fulfillment",
        page="request",
        cu=cu
    )

# ---------- Queue (Staff) ----------
@fulfillment_bp.route("/queue", methods=["GET","POST"])
@login_required
def queue():
    u = _require_staff()
    if not u: 
        return redirect(url_for("home.index"))

    if request.method == "POST":
        rid = int(request.form.get("rid") or 0)
        status = request.form.get("status") or "Received"
        cancellation_reason = request.form.get("cancellation_reason", "")
        
        archive = (status == "Archive") or (status == "Cancelled") or (status == "Completed")
        
        # Store cancellation reason if cancelled
        if status == "Cancelled" and cancellation_reason:
            with get_db_connection("fulfillment") as conn:
                cursor = conn.cursor()
                cursor.execute("""
                    UPDATE fulfillment_requests 
                    SET notes = ?
                    WHERE id = ?
                """, (f"CANCELLED: {cancellation_reason}", rid))
                conn.commit()
                cursor.close()
        
        update_status(
            rid, 
            status,
            archive=archive,
            staff_id=u["id"],
            staff_name=u["username"]
        )
        
        action_detail = f"rid={rid}, status={status}"
        if cancellation_reason:
            action_detail += f", reason={cancellation_reason}"
        
        record_audit(u, "update_status", "fulfillment", action_detail)
        
        flash(f"Request #{rid} updated to {status}.", "success")
        return redirect(url_for("fulfillment.queue"))

    # Location filtering
    from app.modules.auth.security import should_filter_by_location
    should_filter, location = should_filter_by_location(u)
    
    rows = list_queue(location if should_filter else None)
    
    return render_template("fulfillment/queue.html", 
                           active="fulfillment", 
                           page="queue",
                           rows=rows, 
                           statuses=STATUS_CHOICES,
                           user_location=location)

@fulfillment_bp.route("/update-status", methods=["POST"])
@login_required
def update_request_status():
    """Handle status updates from queue."""
    u = _require_staff()
    if not u:
        return redirect(url_for("home.index"))
    
    rid = int(request.form.get("rid") or 0)
    status = request.form.get("status") or "Received"
    cancellation_reason = request.form.get("cancellation_reason", "")
    
    # ONLY Archive and Cancelled move to archive
    archive = status in ["Archive", "Cancelled"]
    
    # Store cancellation reason if cancelled
    if status == "Cancelled" and cancellation_reason:
        with get_db_connection("fulfillment") as conn:
            cursor = conn.cursor()
            cursor.execute("""
                UPDATE fulfillment_requests 
                SET notes = CASE 
                    WHEN notes IS NULL OR notes = '' THEN ?
                    ELSE notes + CHAR(13) + CHAR(10) + ?
                END
                WHERE id = ?
            """, (f"CANCELLED: {cancellation_reason}", f"CANCELLED: {cancellation_reason}", rid))
            conn.commit()
            cursor.close()
    
    update_status(
        rid, 
        status,
        archive=archive,
        staff_id=u["id"],
        staff_name=u["username"]
    )
    
    action_detail = f"rid={rid}, status={status}"
    if cancellation_reason:
        action_detail += f", reason={cancellation_reason}"
    
    record_audit(u, "update_status", "fulfillment", action_detail)
    
    flash(f"Request #{rid} updated to {status}.", "success")
    return redirect(url_for("fulfillment.queue"))

@fulfillment_bp.route("/request/<int:request_id>")
@login_required
def view_request(request_id: int):
    """View detailed fulfillment request."""
    cu = current_user()
    
    # Check permissions
    effective_perms = PermissionManager.get_effective_permissions(cu)
    if not (effective_perms.get("can_fulfillment_customer") or 
            effective_perms.get("can_fulfillment_service") or 
            effective_perms.get("can_fulfillment_manager")):
        flash("You don't have access to Fulfillment.", "danger")
        return redirect(url_for("home.index"))
    
    with get_db_connection("fulfillment") as conn:
        cursor = conn.cursor()
        
        # Get request details
        cursor.execute("""
            SELECT 
                fr.*,
                sr.request_number,
                sr.location,
                sr.created_at,
                sr.completed_at as sr_completed_at
            FROM fulfillment_requests fr
            LEFT JOIN service_requests sr ON fr.id = sr.id
            WHERE fr.id = ?
        """, (request_id,))
        
        row = cursor.fetchone()
        if not row:
            flash("Request not found.", "warning")
            return redirect(url_for("fulfillment.queue"))
        
        # Convert to dict
        request_data = {
            'id': row[0],
            'requester_id': row[1],
            'requester_name': row[2],
            'description': row[3],
            'date_submitted': row[4],
            'date_due': row[5],
            'total_pages': row[6],
            'status': row[7],
            'assigned_staff_id': row[8],
            'assigned_staff_name': row[9],
            'options_json': row[10],
            'notes': row[11],
            'is_archived': row[12],
            'completed_at': row[13],
            'ts_utc': row[14],
            'request_number': row[15],
            'location': row[16],
            'created_at': row[17],
            'sr_completed_at': row[18]
        }
        
        # Get attached files
        cursor.execute("""
            SELECT id, orig_name, ext, bytes, ts_utc
            FROM fulfillment_files
            WHERE request_id = ? AND ok = 1
            ORDER BY ts_utc DESC
        """, (request_id,))
        files = cursor.fetchall()
        
        cursor.close()
    
    # Record audit
    record_audit(cu, "view_fulfillment_request", "fulfillment", 
                f"Viewed request #{request_id}")
    
    return render_template(
        "fulfillment/view_request.html",
        active="fulfillment",
        page="view",
        request=request_data,
        files=files
    )

@fulfillment_bp.route("/request/<int:request_id>/edit", methods=["GET", "POST"])
@login_required
def edit_request(request_id: int):
    """Edit fulfillment request (M3B/M3C only)."""
    cu = current_user()
    
    # Check permissions - only M3B (Service) and M3C (Manager) can edit
    if not _user_can_staff(cu):
        flash("You need M3B (Service) or M3C (Manager) permissions to edit requests.", "danger")
        return redirect(url_for("home.index"))
    
    with get_db_connection("fulfillment") as conn:
        cursor = conn.cursor()
        
        if request.method == "POST":
            # Get form data
            description = request.form.get("description", "").strip()
            total_pages = int(request.form.get("total_pages", 0) or 0)
            date_due = request.form.get("date_due", "") or None
            notes = request.form.get("notes", "").strip()
            status = request.form.get("status", "Received")
            
            if not description:
                flash("Description is required.", "danger")
                return redirect(url_for("fulfillment.edit_request", request_id=request_id))
            
            # Update both tables
            cursor.execute("""
                UPDATE fulfillment_requests
                SET description = ?,
                    total_pages = ?,
                    date_due = ?,
                    notes = ?,
                    status = ?,
                    assigned_staff_id = ?,
                    assigned_staff_name = ?
                WHERE id = ?
            """, (description, total_pages, date_due, notes, status, cu['id'], cu['username'], request_id))
            
            cursor.execute("""
                UPDATE service_requests
                SET description = ?,
                    status = ?,
                    assigned_to = ?
                WHERE id = ?
            """, (description, status, cu['id'], request_id))
            
            conn.commit()
            cursor.close()
            
            # Record audit
            record_audit(cu, "edit_fulfillment_request", "fulfillment", 
                        f"Edited request #{request_id}")
            
            flash(f"Request #{request_id} updated successfully.", "success")
            return redirect(url_for("fulfillment.view_request", request_id=request_id))
        
        # GET - Load request data
        cursor.execute("""
            SELECT 
                fr.*,
                sr.request_number,
                sr.location,
                sr.created_at
            FROM fulfillment_requests fr
            LEFT JOIN service_requests sr ON fr.id = sr.id
            WHERE fr.id = ?
        """, (request_id,))
        
        row = cursor.fetchone()
        if not row:
            flash("Request not found.", "warning")
            return redirect(url_for("fulfillment.queue"))
        
        # Convert to dict
        request_data = {
            'id': row[0],
            'requester_id': row[1],
            'requester_name': row[2],
            'description': row[3],
            'date_submitted': row[4],
            'date_due': row[5],
            'total_pages': row[6],
            'status': row[7],
            'assigned_staff_id': row[8],
            'assigned_staff_name': row[9],
            'options_json': row[10],
            'notes': row[11],
            'is_archived': row[12],
            'completed_at': row[13],
            'ts_utc': row[14],
            'request_number': row[15],
            'location': row[16],
            'created_at': row[17]
        }
        
        cursor.close()
    
    return render_template(
        "fulfillment/edit_request.html",
        active="fulfillment",
        page="edit",
        request=request_data,
        statuses=STATUS_CHOICES
    )

